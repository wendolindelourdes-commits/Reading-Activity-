<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World Cup Writing Challenge</title>
    <style>
        :root {
            --mex-green: #006847;
            --mex-white: #ffffff;
            --mex-red: #CE1126;
            --pitch-dark: #1A3A2B;
            --gold: #FFD700;
            --light-gray: #f4f6f5;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--pitch-dark) 0%, #0d2016 100%);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }

        .main-container {
            max-width: 800px;
            width: 100%;
            background: var(--mex-white);
            padding: 40px 30px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 4px solid var(--mex-green);
            position: relative;
        }

        /* Línea tricolor superior */
        .main-container::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 8px;
            border-radius: 12px 12px 0 0;
            background: linear-gradient(to right, var(--mex-green) 33%, var(--mex-white) 33%, var(--mex-white) 66%, var(--mex-red) 66%);
        }

        .main-title {
            font-family: 'Impact', 'Arial Black', sans-serif;
            color: var(--mex-green);
            text-align: center;
            text-transform: uppercase;
            font-size: 2.6rem;
            letter-spacing: 1px;
            margin-top: 10px;
            margin-bottom: 30px;
            text-shadow: 2px 2px 0px rgba(0,0,0,0.1);
        }

        h2 {
            font-family: 'Impact', 'Arial Black', sans-serif;
            color: var(--mex-red);
            text-transform: uppercase;
            font-size: 1.8rem;
            border-bottom: 3px dashed var(--mex-green);
            padding-bottom: 5px;
            margin-top: 40px;
        }

        /* Caja de Texto */
        .text-box {
            line-height: 1.7;
            font-size: 1.15rem;
            text-align: justify;
            background: #f0f7f4;
            padding: 25px;
            border: 2px solid var(--mex-green);
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: inset 0 0 10px rgba(0,104,71,0.1);
        }

        .text-box h3 {
            font-family: 'Impact', sans-serif;
            color: var(--mex-green);
            font-size: 1.6rem;
            margin-top: 0;
            text-align: center;
            text-transform: uppercase;
        }

        /* Bloques de Preguntas */
        .question-block {
            margin-bottom: 25px;
            padding: 20px;
            background: var(--light-gray);
            border-radius: 8px;
            border-left: 5px solid #ccc;
            transition: all 0.3s ease;
        }

        .question-block p {
            margin-top: 0;
            font-size: 1.1rem;
            font-weight: bold;
            color: #111;
        }

        .options-label {
            display: block;
            margin: 10px 0;
            padding: 12px;
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .options-label:hover {
            border-color: var(--mex-green);
            background: #e6f2ee;
        }

        .options-label input {
            margin-right: 12px;
            transform: scale(1.2);
        }

        /* Pizarra de Marcador Final */
        .scoreboard {
            background: #222;
            color: #fff;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            border: 4px solid var(--gold);
            margin-top: 40px;
            margin-bottom: 20px;
        }

        .scoreboard h3 {
            font-family: 'Impact', sans-serif;
            margin: 0;
            color: var(--gold);
            font-size: 1.5rem;
            letter-spacing: 2px;
        }

        .score-digits {
            font-family: 'Impact', sans-serif;
            font-size: 3.5rem;
            color: #fff;
            margin: 10px 0;
            text-shadow: 0 0 10px var(--gold);
        }

        /* Botones */
        .btn {
            font-family: 'Impact', 'Arial Black', sans-serif;
            display: block;
            width: 100%;
            background-color: var(--mex-green);
            color: white;
            border: none;
            padding: 16px;
            font-size: 1.4rem;
            text-transform: uppercase;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 4px 0px #004d34;
            margin-top: 30px;
            transition: all 0.1s ease;
        }

        .btn:hover {
            background-color: #005238;
            transform: translateY(2px);
            box-shadow: 0 2px 0px #004d34;
        }

        /* === CORRECCIONES CON COLORES === */
        .question-block.correct-block {
            border-left-color: #2e7d32 !important;
            background-color: #edf7ed !important;
        }

        .question-block.incorrect-block {
            border-left-color: #c62828 !important;
            background-color: #fdecea !important;
        }

        .options-label.user-wrong {
            background-color: #ffcdd2 !important;
            border-color: #e57373 !important;
            color: #c62828;
            font-weight: bold;
        }

        .options-label.correct-target {
            background-color: #c8e6c9 !important;
            border-color: #81c784 !important;
            color: #2e7d32;
            font-weight: bold;
        }

        .hidden { display: none; }
    </style>
</head>
<body>

<div class="main-container">
    <div class="main-title">🏆 World Cup Writing Challenge 🏆</div>

    <div class="text-box">
        <h3>Why Mexico Deserved to Win the FIFA World Cup</h3>
        <p>Have you ever supported a team with all your heart? I believe Mexico deserved to win the FIFA World Cup because the team showed talent, teamwork, and determination during the tournament.</p>
        <p>First, Mexico played every match with confidence and never gave up. The players worked together and fought until the final whistle. Julián Quiñones helped the team with his speed, strong attacks, and excellent passing. He created many chances to score and encouraged his teammates to keep trying.</p>
        <p>Second, Gilberto Mora proved that young players can make a big difference. Even though he was one of the youngest players, he stayed calm under pressure and made smart decisions on the field. His performance gave hope to many young football fans in Mexico.</p>
        <p>Finally, Mexico had amazing support from its fans. Thousands of people traveled to the stadiums, and millions watched the matches from home. The fans never stopped cheering, even during difficult moments. Their passion showed how much the team meant to the country.</p>
        <p>Some people believe another team deserved the trophy, but football is not only about winning. It is also about effort, teamwork, and inspiring others. For these reasons, I believe Mexico should have been the FIFA World Cup champion.</p>
    </div>

    <form id="quiz-form">
        <h2>⚽ Part 1: Text Structure & Purpose</h2>
        <div id="part1-container"></div>

        <h2>⚽ Part 2: Match Details & Facts</h2>
        <div id="part2-container"></div>

        <div id="final-scoreboard" class="scoreboard hidden">
            <h3>FINAL SCORE</h3>
            <div class="score-digits" id="score-text">0 / 8</div>
            <p id="accuracy-text" style="margin:0; font-weight:bold; color:var(--gold); font-size:1.2rem;"></p>
        </div>

        <button type="button" class="btn" id="submit-btn" onclick="checkQuiz()">🏁 Check Results</button>
        <button type="button" class="btn hidden" id="retry-btn" onclick="location.reload()" style="background-color: var(--mex-red); box-shadow: 0 4px 0px #8a0b18;">🔄 Try Again (Rematch)</button>
    </form>
</div>

<script>
    // Banco de datos dividido en las dos partes solicitadas
    const part1Questions = [
        { id: "q1", q: "1. What is the main idea of the text?", a: "Mexico had the best stadiums.", b: "Mexico deserved to win the FIFA World Cup.", c: "The FIFA World Cup is the biggest tournament.", d: "Fans only care about winning.", correct: "b" },
        { id: "q2", q: "2. What type of text is this?", a: "A news report", b: "A persuasive text", c: "A story", d: "A biography", correct: "b" },
        { id: "q3", q: "3. What is the writer’s purpose?", a: "To entertain readers with a story.", b: "To explain the history of the FIFA World Cup.", c: "To convince readers that Mexico deserved to win the World Cup.", d: "To describe different football teams.", correct: "c" },
        { id: "q4", q: "4. Which title best matches the text?", a: "Football Around the World", b: "Why Mexico Deserved to Win the FIFA World Cup", c: "The Best World Cup Stadiums", d: "Young Players in Football", correct: "b" }
    ];

    const part2Questions = [
        { id: "q5", q: "5. Which player is described as having speed, strong attacks, and excellent passing?", a: "Raúl Jiménez", b: "Gilberto Mora", c: "Julián Quiñones", d: "Edson Álvarez", correct: "c" },
        { id: "q6", q: "6. What qualities did Gilberto Mora show during the tournament?", a: "He scored the most goals.", b: "He stayed calm under pressure and made smart decisions.", c: "He became the team captain.", d: "He traveled with the fans.", correct: "b" },
        { id: "q7", q: "7. How did the fans support Mexico?", a: "They only watched the final match.", b: "They stopped cheering after a loss.", c: "Thousands traveled to the stadiums, and millions watched from home.", d: "They only supported the team on social media.", correct: "c" },
        { id: "q8", q: "8. According to the author, football is not only about:", a: "Playing at home.", b: "Winning.", c: "Traveling.", d: "Scoring goals.", correct: "b" }
    ];

    const allQuestions = [...part1Questions, ...part2Questions];

    // Renderizar preguntas organizadas en sus respectivos bloques
    function renderQuiz() {
        const container1 = document.getElementById('part1-container');
        const container2 = document.getElementById('part2-container');

        part1Questions.forEach(item => container1.appendChild(createQuestionHTML(item)));
        part2Questions.forEach(item => container2.appendChild(createQuestionHTML(item)));
    }

    function createQuestionHTML(item) {
        const qBlock = document.createElement('div');
        qBlock.className = 'question-block';
        qBlock.id = `block-${item.id}`;
        qBlock.innerHTML = `
            <p>${item.q}</p>
            <label class="options-label" id="label-${item.id}-a"><input type="radio" name="${item.id}" value="a" required> a) ${item.a}</label>
            <label class="options-label" id="label-${item.id}-b"><input type="radio" name="${item.id}" value="b"> b) ${item.b}</label>
            <label class="options-label" id="label-${item.id}-c"><input type="radio" name="${item.id}" value="c"> c) ${item.c}</label>
            <label class="options-label" id="label-${item.id}-d"><input type="radio" name="${item.id}" value="d"> d) ${item.d}</label>
        `;
        return qBlock;
    }

    function checkQuiz() {
        const form = document.getElementById('quiz-form');
        if (!form.checkValidity()) {
            alert("🛑 ¡Falta juego! Por favor responde todas las preguntas antes de revisar los resultados.");
            return;
        }

        let totalScore = 0;

        allQuestions.forEach((item) => {
            const selectedRadio = document.querySelector(`input[name="${item.id}"]:checked`);
            const userAns = selectedRadio.value;
            const isCorrect = userAns === item.correct;

            const qBlock = document.getElementById(`block-${item.id}`);
            
            // Pintar los bloques de las preguntas según el resultado
            if (isCorrect) {
                totalScore++;
                qBlock.classList.add('correct-block');
            } else {
                qBlock.classList.add('incorrect-block');
                // Marcar error del usuario en rojo
                document.getElementById(`label-${item.id}-${userAns}`).classList.add('user-wrong');
            }

            // Resaltar siempre el acierto correcto en verde
            document.getElementById(`label-${item.id}-${item.correct}`).classList.add('correct-target');

            // Bloquear los controles para que no se cambien las respuestas
            document.getElementsByName(item.id).forEach(input => input.disabled = true);
        });

        // Mostrar Pizarra de resultados final abajo de todo
        const scoreboard = document.getElementById('final-scoreboard');
        scoreboard.classList.remove('hidden');
        document.getElementById('score-text').innerText = `${totalScore} / ${allQuestions.length}`;
        
        const percentage = Math.round((totalScore / allQuestions.length) * 100);
        document.getElementById('accuracy-text').innerText = `ACCURACY: ${percentage}%`;

        // Intercambiar botones
        document.getElementById('submit-btn').classList.add('hidden');
        document.getElementById('retry-btn').classList.remove('hidden');

        // Hacer un ligero scroll hacia abajo para ver el marcador final
        scoreboard.scrollIntoView({ behavior: 'smooth' });
    }

    window.onload = renderQuiz;
</script>

</body>
</html>
